# Backend configuration — copy to .env and edit.
# Loaded manually by whatever process manager you use (flask run / uvicorn /
# python app.py). The code reads these with os.environ.get(...).

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/megamind

# Secret used to sign JWT session tokens. Generate a random one for production.
# e.g. python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change_me_in_production
