# Frontend configuration — copy to .env and edit.
# Vite exposes any variable starting with VITE_ to client code.

# Optional: absolute base URL for the API. Leave blank during local dev so
# the Vite proxy in vite.config.ts forwards /api/* to Flask on :5000.
VITE_API_BASE_URL=

# Optional: override the dev-server proxy target (defaults to http://localhost:5000).
VITE_API_PROXY_TARGET=http://localhost:5000
